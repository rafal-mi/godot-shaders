void fragment() {
// Input:2
	vec4 n_out2p0 = COLOR;
	float n_out2p1 = n_out2p0.r;


	vec3 n_out3p0;
// If:3
	float n_in3p1 = 0.85900;
	float n_in3p2 = 0.00100;
	vec3 n_in3p3 = vec3(1.00000, 1.00000, 0.00000);
	if(abs(n_out2p1 - n_in3p1) < n_in3p2)
